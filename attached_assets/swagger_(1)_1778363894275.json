    "/shipments/detail": {
      "get": {
        "responses": {
          "200": {
            "description": "The operation was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackDetailOutput"
                }
              }
            }
          }
        },
        "description": "<br>To track shipments by consignment number, for multiple CN(s) use comma between them, multiple CN(s) should be up to 10.",
        "parameters": [
          {
            "name": "consignmentNo",
            "in": "query",
            "description": "This is your shipment tracking CN# or Reference No.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "Max. 20"
            }
          }
        ],
        "summary": "Track Shipment by CN",
        "tags": [
          "Track Shipment"
        ]
      }
    },
