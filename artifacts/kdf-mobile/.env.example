# ============================================================
# KDF RIDER LAHORE — Environment Variables
# ============================================================
# Copy to .env.local for local dev (never commit .env.local)
# For EAS builds: set these in eas.json under each profile's "env" key.
# ============================================================

# ----------------------------------------------------------
# REQUIRED — Express @workspace/api-server origin (no trailing slash, no /api suffix)
# Must be https://api.<your-domain> — NOT the storefront or admin static host.
# Set in eas.json "env" for each EAS build profile (see artifacts/kdf-mobile/eas.json).
# ----------------------------------------------------------
EXPO_PUBLIC_API_URL=https://api.khanbabadryfruits.com

# ----------------------------------------------------------
# AUTO-SET by Replit dev workflow — do not set manually
# ----------------------------------------------------------
# EXPO_PUBLIC_DOMAIN=<auto>
# EXPO_PUBLIC_REPL_ID=<auto>
