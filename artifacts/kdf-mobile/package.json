{
  "name": "@workspace/kdf-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_UNSTABLE_HEADLESS=1 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN pnpm exec expo start --localhost --port $PORT",
    "android": "expo run:android",
    "build": "echo 'Mobile app — no web build required for deployment'",
    "build:preview": "eas build -p android --profile preview",
    "build:apk": "eas build -p android --profile production-apk",
    "build:aab": "eas build -p android --profile production",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@tanstack/react-query": "5.100.9",
    "expo": "~55.0.23",
    "expo-av": "^16.0.8",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-device": "~55.0.16",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.15",
    "expo-location": "~55.1.9",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.17",
    "expo-updates": "~55.0.21",
    "expo-web-browser": "~55.0.15",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/cli": "55.0.29",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^55.0.21",
    "typescript": "~5.9.2"
  }
}
