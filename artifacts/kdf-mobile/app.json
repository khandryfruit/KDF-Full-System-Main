{
  "expo": {
    "name": "KDF RIDER LAHORE",
    "slug": "kdf-mobile",
    "version": "3.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kdf-mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2137"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kdfnuts.rider",
      "buildNumber": "10",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "KDF Rider needs your location for delivery navigation.",
        "NSLocationAlwaysUsageDescription": "KDF Rider uses your location to track deliveries."
      }
    },
    "android": {
      "package": "com.kdfnuts.rider",
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D2137"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://khanbabadryfruits.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "KDF Rider needs location access for live delivery tracking.",
          "locationWhenInUsePermission": "KDF Rider needs location access for live delivery tracking."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00B85A",
          "sounds": [
            "./assets/audio/new_order.wav"
          ],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-background-fetch",
      "expo-task-manager"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "f5433930-a95c-4ac1-857f-dfdafc2fe4d1"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f5433930-a95c-4ac1-857f-dfdafc2fe4d1",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    }
  }
}
